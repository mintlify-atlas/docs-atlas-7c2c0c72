  "keyFeatures": [
    "Lead and opportunity management with assignment workflows",
    "Commission calculation engine with rule-based plans",
    "Multi-channel communications (Email, WhatsApp)",
    "Client portfolio management (cartera)",
    "Power BI reporting and analytics integration",
    "Azure AD authentication and role-based access control",
    "Corporate and retail lead separation",
    "Interaction tracking and client history"
  ],
  "publicApiSurface": [
    "POST /api/leads - Create a new lead",
    "GET /api/leads - List leads with filtering",
    "PUT /api/leads/{id} - Update lead details",
    "DELETE /api/leads/{id} - Delete a lead",
    "POST /api/leads/assign - Assign lead to user",
    "GET /api/commission-plans - List commission plans",
    "POST /api/commission-plans - Create commission plan",
    "PUT /api/commission-plans/{id} - Update commission plan",
    "POST /api/commission-plans/{id}/approve - Approve commission plan",
    "POST /api/commission-rules - Create commission rule",
    "GET /api/interactions - List interactions",
    "POST /api/interactions - Create interaction",
    "GET /api/interactions/{lead_id} - Get interactions by lead",
    "POST /api/emails/send - Send email",
    "GET /api/emails/templates - List email templates",
    "POST /api/whatsapp/send - Send WhatsApp message",
    "GET /api/whatsapp/accounts - List WhatsApp accounts",
    "GET /api/cartera/grid - Get client portfolio grid",
    "POST /api/cartera/reveal - Reveal client contact info",
    "GET /api/reports - List available reports",
    "GET /api/users - List users",
    "GET /api/profile - Get user profile",
    "PUT /api/profile/basic - Update basic profile",
    "GET /api/sessions - Get active sessions"
  ]
